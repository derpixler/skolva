# Server
APP_PORT=8080
APP_ENV=development

# Database
DATABASE_URL=postgres://vv:vv@localhost:5432/vv?sslmode=disable

# Auth
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-in-production
JWT_EXPIRY_HOURS=24
ZFA_REQUIRED_ROLES=admin,vorstand,kassierer

# AI (optional, activate in TP9)
AI_PROVIDER_URL=
AI_API_KEY=
AI_MODEL=
AI_GDPR_MODE=disabled

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# Mail
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@skolva.org

# Modules
MODULES_ENABLED=auth,crm,groups,documents,audit,sharing

# Logging
LOG_LEVEL=debug
